body {
    font-family: Arial, sans-serif;
    background: #f5f5f5;
    padding: 20px;
}

.products {
    display: flex;
    gap: 20px;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    width: 200px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
}

a {
    text-decoration: none;
    color: blue;
}
